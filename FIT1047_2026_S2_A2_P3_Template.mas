///
/// Implement your subroutine SubInputAndExtractOperandsAndOperator here. (Task 3.1)
///
SubInputAndExtractOperandsAndOperator, HEX 0

/ Initialize both operands to 0
Load ZERO
Store Operand1
Store Operand2

/ === Read First Operand ===
/ Read digits until we hit an operator (+, -, *, /)
S31_ReadOp1,
    InpU                  / read one Unicode character
    Store S31_Char        / save the character

    / Check if character is '+' (Unicode 43)
    Subt CharPlus
    Skipcond 400          / skip next if AC == 0 (it is '+')
    Jump S31_ChkMinus
    Load CharPlus
    Store Operator
    Jump S31_ReadOp2      / operator found, go read second operand

S31_ChkMinus,
    Load S31_Char
    Subt CharMinus        / check for '-' (Unicode 45)
    Skipcond 400
    Jump S31_ChkMul
    Load CharMinus
    Store Operator
    Jump S31_ReadOp2

S31_ChkMul,
    Load S31_Char
    Subt CharMul          / check for '*' (Unicode 42)
    Skipcond 400
    Jump S31_ChkDiv
    Load CharMul
    Store Operator
    Jump S31_ReadOp2

S31_ChkDiv,
    Load S31_Char
    Subt CharDiv          / check for '/' (Unicode 47)
    Skipcond 400
    Jump S31_Dig1         / not an operator, must be a digit
    Load CharDiv
    Store Operator
    Jump S31_ReadOp2

/ It is a digit - add it into Operand1
/ Operand1 = Operand1 * 10 + (char - '0')
S31_Dig1,
    Load Operand1
    Store S31_N           / save n
    Add S31_N             / AC = 2n
    Store S31_2N
    Add S31_2N            / AC = 4n
    Store S31_4N
    Add S31_4N            / AC = 8n
    Add S31_2N            / AC = 10n
    Store Operand1

    Load S31_Char
    Subt CharZero         / convert Unicode digit to numeric value (0-9)
    Add Operand1
    Store Operand1
    Jump S31_ReadOp1      / read next character

/ === Read Second Operand ===
/ Read digits until we hit '='
S31_ReadOp2,
    InpU
    Store S31_Char

    / Check if character is '=' (Unicode 61) - stop reading
    Subt CharEquals
    Skipcond 400
    Jump S31_Dig2
    Jump S31_Done         / it is '=', we are done

/ It is a digit - add it into Operand2
S31_Dig2,
    Load Operand2
    Store S31_N
    Add S31_N
    Store S31_2N
    Add S31_2N
    Store S31_4N
    Add S31_4N
    Add S31_2N
    Store Operand2

    Load S31_Char
    Subt CharZero
    Add Operand2
    Store Operand2
    Jump S31_ReadOp2

S31_Done,
JumpI SubInputAndExtractOperandsAndOperator

/ Local variables for Task 3.1
S31_Char, HEX 0
S31_N,    HEX 0
S31_2N,   HEX 0
S31_4N,   HEX 0

///
/// Implement your subroutine SubCal here. (Task 3.2)
///
SubCal, HEX 0

/ Is it '+' ?
Load Operator
Subt CharPlus
Skipcond 400
Jump S32_ChkMinus
Load Operand1
Add Operand2
Store CalResult
Jump S32_Done

/ Is it '-' ?
S32_ChkMinus,
Load Operator
Subt CharMinus
Skipcond 400
Jump S32_ChkMul
Load Operand1
Subt Operand2
Store CalResult
Jump S32_Done

/ Is it '*' ? Use repeated addition (loop Operand2 times, add Operand1 each time)
S32_ChkMul,
Load Operator
Subt CharMul
Skipcond 400
Jump S32_Div
Load ZERO
Store CalResult
Load Operand2
Store S32_Count

S32_MulLoop,
    Load S32_Count
    Skipcond 400          / skip next if count == 0 (finished)
    Jump S32_MulAdd
    Jump S32_Done
S32_MulAdd,
    Load CalResult
    Add Operand1
    Store CalResult
    Load S32_Count
    Subt ONE
    Store S32_Count
    Jump S32_MulLoop

/ Is it '/' ? Use repeated subtraction
S32_Div,
Load ZERO
Store CalResult
Load Operand1
Store S32_Remain

S32_DivLoop,
    Load S32_Remain
    Subt Operand2         / AC = remaining - divisor
    Skipcond 000          / skip next if AC < 0 (remaining < divisor, stop)
    Jump S32_DivCont
    Jump S32_Done

S32_DivCont,
    Store S32_Remain      / AC already holds remaining - Operand2, save it
    Load CalResult
    Add ONE
    Store CalResult
    Jump S32_DivLoop

S32_Done,
JumpI SubCal

/ Local variables for Task 3.2
S32_Count,  HEX 0
S32_Remain, HEX 0

